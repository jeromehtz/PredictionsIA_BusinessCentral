{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "bc26-6080",
            "type": "al",
            "request": "launch",
            "environmentType": "OnPrem",
            "server": "http://bc26-6080",
            "serverInstance": "BC",
            "tenant": "default",
            "port": 7049,
            "authentication": "UserPassword",
            "breakOnError": true,
            "launchBrowser": true,
            "enableLongRunningSqlStatements": true,
            "enableSqlInformationDebugger": true,
            "schemaUpdateMode": "ForceSync"
        },
        {
            "name": "bc26fr",
            "type": "al",
            "request": "launch",
            "environmentType": "OnPrem",
            "server": "http://bc26fr",
            "serverInstance": "BC",
            "tenant": "default",
            "port": 7049,
            "authentication": "UserPassword",
            "breakOnError": true,
            "launchBrowser": true,
            "enableLongRunningSqlStatements": true,
            "enableSqlInformationDebugger": true,
            "schemaUpdateMode": "ForceSync"
        },
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
